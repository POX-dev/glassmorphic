---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Glassmorphic OS Interface" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-gray-900 text-white overflow-hidden select-none">
		<slot />
	</body>
</html>

<style is:global>
	/* Global Glassmorphic Variables */
	:root {
		--glass-border: rgba(255, 255, 255, 0.2);
		--glass-surface: rgba(255, 255, 255, 0.1);
		--glass-highlight: rgba(255, 255, 255, 0.05);
	}
	
	/* The Wallpaper */
	body {
		background: 
			radial-gradient(circle at 15% 50%, rgba(76, 29, 149, 0.4), transparent 25%),
			radial-gradient(circle at 85% 30%, rgba(14, 165, 233, 0.4), transparent 25%),
			linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
	}
</style>